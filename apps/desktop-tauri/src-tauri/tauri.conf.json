{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexBar4Windows",
  "version": "1.0.0",
  "identifier": "com.codexbar4windows.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodexBar4Windows",
        "width": 380,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": true,
        "windowEffects": {
          "effects": ["mica", "acrylic"],
          "state": "active"
        }
      },
      {
        "label": "settings",
        "title": "CodexBar4Windows Preferences",
        "url": "index.html#/settings",
        "width": 880,
        "height": 620,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "visible": false,
        "resizable": true,
        "shadow": true,
        "windowEffects": {
          "effects": ["mica", "acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "windows": {
        "installMode": "passive"
      },
      "endpoints": [
        "https://github.com/JRub19/CodexBar4Windows/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_BASE64_MINISIGN_PUBLIC_KEY"
    }
  }
}
